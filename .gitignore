# Built application files
*.apk
*.aar
*.ap_
*.aab

# Files for the ART/Dalvik VM
*.dex

# Java class files
*.class

# Generated files
bin/
gen/
out/
release/

# Gradle files
.gradle/
build/
/build

# Local configuration file (sdk path, etc)
local.properties
/local.properties

# Log Files
*.log

# Android Studio Navigation editor temp files
.navigation/

# Android Studio captures folder
captures/
/captures

# IntelliJ / Android Studio
*.iml
*.ipr
*.iws
.idea/
/.idea/caches
/.idea/libraries
/.idea/modules.xml
/.idea/workspace.xml
/.idea/navEditor.xml
/.idea/assetWizardSettings.xml

# Keystore files
*.jks
*.keystore

# External native build folder generated in Android Studio 2.2 and later
.externalNativeBuild/
.cxx/

# OS-generated
.DS_Store
Thumbs.db

# Claude Code local settings (machine-specific permission allowlist)
.claude/settings.local.json

# Downloaded model files (runtime files land in app-private filesDir, but be defensive)
app/src/main/assets/models/
